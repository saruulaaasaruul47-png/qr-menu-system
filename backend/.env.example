NODE_ENV=production

# Render Postgres internal connection string, or local Postgres URL.
DATABASE_URL=postgresql://qrsystem:qrsystem_dev_password@localhost:5432/qrsystem

# Local service ports. Render sets PORT automatically for each deployed service.
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
RESTAURANT_SERVICE_PORT=3002
MENU_SERVICE_PORT=3003
ORDER_SERVICE_PORT=3004
PAYMENT_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006
ANALYTICS_SERVICE_PORT=3007
QR_SERVICE_PORT=3008
LOYALTY_SERVICE_PORT=3009
AUDIT_SERVICE_PORT=3010

# Comma-separated frontend origins. Example: https://your-frontend.vercel.app
CORS_ORIGIN=http://localhost:5173
APP_PUBLIC_URL=http://localhost:5173

JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_ORDER_CURRENCY=mnt
STRIPE_ORDER_AMOUNT_MULTIPLIER=1
PAYMENT_WEBHOOK_SECRET=replace-with-a-random-provider-webhook-secret

# Email notifications and password reset codes.
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_USER=youraddress@gmail.com,
# SMTP_PASS=your 16-character Google app password, SMTP_FROM=QR Menu <youraddress@gmail.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=QR Menu <no-reply@qr-menu.local>

# Public URL prefix for uploaded assets.
STORAGE_BASE_URL=/uploads

# Optional async event bus. Leave empty to store events in the DB only.
RABBITMQ_URL=

# API gateway service targets.
# Local: keep localhost.
# Render multi-service deploy: use each Render service URL.
AUTH_SERVICE_URLS=http://localhost:3001
RESTAURANT_SERVICE_URLS=http://localhost:3002
MENU_SERVICE_URLS=http://localhost:3003
ORDER_SERVICE_URLS=http://localhost:3004
PAYMENT_SERVICE_URLS=http://localhost:3005
NOTIFICATION_SERVICE_URLS=http://localhost:3006
ANALYTICS_SERVICE_URLS=http://localhost:3007
QR_SERVICE_URLS=http://localhost:3008
LOYALTY_SERVICE_URLS=http://localhost:3009
AUDIT_SERVICE_URLS=http://localhost:3010

# Initial admin seed script
SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_PASSWORD=replace-with-a-strong-password
SUPERADMIN_NAME=Super Admin
