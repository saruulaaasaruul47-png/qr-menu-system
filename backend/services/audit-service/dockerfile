FROM node:24-alpine

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY prisma.config.ts ./
COPY prisma ./prisma
ENV DATABASE_URL="postgresql://qrsystem:qrsystem_dev_password@localhost:5432/qrsystem"
RUN npx prisma generate

COPY lib ./lib
COPY shared ./shared
COPY services/audit-service ./services/audit-service

WORKDIR /app/services/audit-service

EXPOSE 3010

CMD ["sh", "-c", "npx prisma db push --schema /app/prisma/schema.prisma --url \"$DATABASE_URL\" && node app.js"]

