// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/**
 * ================= ENUMS =================
 */

enum Role {
  SUPER_ADMIN
  OWNER
  MANAGER
  WAITER
  KITCHEN
  CASHIER
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
}

enum OrderSource {
  QR
  CASHIER
  WAITER
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

/**
 * ================= RESTAURANT =================
 */

model Restaurant {
  id          String  @id @default(uuid())
  name        String
  description String?
  logoUrl     String?
  bannerUrl   String?
  faviconUrl  String?
  themeColor  String?
  font        String?
  qrDesign    Json    @default("{}")
  phone       String?
  address     String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  tables          Table[]
  categories      Category[]
  foods           Food[]
  orders          Order[]
  coupons         Coupon[]
  qrScans         QrScan[]
  modifierGroups  FoodModifierGroup[]
  modifierOptions FoodModifierOption[]
  subscription    Subscription?
  auditLogs       AuditLog[]
}

/**
 * ================= USER =================
 */

model User {
  id           String  @id @default(uuid())
  restaurantId String?

  name     String
  email    String @unique
  password String

  role        Role
  permissions Json @default("[]")

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  auditLogs  AuditLog[]
}

/**
 * ================= TABLE =================
 */

model Table {
  id           String @id @default(uuid())
  restaurantId String

  name      String
  number    Int?
  capacity  Int         @default(1)
  status    TableStatus @default(AVAILABLE)
  qrCodeUrl String?
  isActive  Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders     Order[]
  qrScans    QrScan[]

  @@unique([restaurantId, number])
}

/**
 * ================= CATEGORY =================
 */

model Category {
  id           String @id @default(uuid())
  restaurantId String

  name        String
  description String?

  createdAt DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  foods      Food[]
}

/**
 * ================= FOOD =================
 */

model Food {
  id           String  @id @default(uuid())
  restaurantId String
  categoryId   String?

  name            String
  nameI18n        Json    @default("{}")
  description     String?
  descriptionI18n Json    @default("{}")
  price           Float
  discountPrice   Float?

  imageUrl    String?
  ingredients Json    @default("[]")
  allergens   Json    @default("[]")

  isAvailable     Boolean @default(true)
  trackInventory  Boolean @default(false)
  stockQuantity   Int?
  isVegetarian    Boolean @default(false)
  isVegan         Boolean @default(false)
  isHalal         Boolean @default(false)
  isSpicy         Boolean @default(false)
  isGlutenFree    Boolean @default(false)
  isNutFree       Boolean @default(false)
  preparationTime Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  category   Category?  @relation(fields: [categoryId], references: [id])

  orderItems      OrderItem[]
  modifierGroups  FoodModifierGroup[]
  modifierOptions FoodModifierOption[]
}

model FoodModifierGroup {
  id           String   @id @default(uuid())
  restaurantId String
  foodId       String
  name         String
  isRequired   Boolean  @default(false)
  minSelect    Int      @default(0)
  maxSelect    Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  food       Food                 @relation(fields: [foodId], references: [id], onDelete: Cascade)
  options    FoodModifierOption[]

  @@index([restaurantId])
  @@index([foodId])
}

model FoodModifierOption {
  id           String   @id @default(uuid())
  restaurantId String
  foodId       String
  groupId      String
  name         String
  priceDelta   Float    @default(0)
  isAvailable  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant       Restaurant                @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  food             Food                      @relation(fields: [foodId], references: [id], onDelete: Cascade)
  group            FoodModifierGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  orderItemOptions OrderItemModifierOption[]

  @@index([restaurantId])
  @@index([foodId])
  @@index([groupId])
}

/**
 * ================= ORDER =================
 */

model Order {
  id           String  @id @default(uuid())
  restaurantId String
  tableId      String?

  guestSessionId String

  source        OrderSource @default(QR)
  status        OrderStatus @default(PENDING)
  totalAmount   Float
  discountAmount Float  @default(0)
  couponCode     String?
  note          String?
  customerPhone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table      Table?     @relation(fields: [tableId], references: [id])

  items   OrderItem[]
  payment Payment?
  couponRedemptions CouponRedemption[]
}

model Coupon {
  id           String @id @default(uuid())
  restaurantId String

  code              String
  type              String  @default("PERCENT")
  discountValue     Float
  minOrderAmount    Float?
  maxDiscountAmount Float?
  usageLimit        Int?
  usedCount         Int     @default(0)
  isActive          Boolean @default(true)
  startsAt          DateTime?
  expiresAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant  Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  redemptions CouponRedemption[]

  @@unique([restaurantId, code])
  @@index([restaurantId])
}

model CouponRedemption {
  id             String @id @default(uuid())
  restaurantId   String
  couponId       String
  orderId        String
  code           String
  discountAmount Float

  createdAt DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([couponId, orderId])
  @@index([restaurantId])
  @@index([couponId])
}

/**
 * ================= ORDER ITEM =================
 */

model OrderItem {
  id String @id @default(uuid())

  orderId String
  foodId  String

  quantity  Int
  price     Float
  modifiers Json?

  order           Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  food            Food                      @relation(fields: [foodId], references: [id])
  selectedOptions OrderItemModifierOption[]
}

model OrderItemModifierOption {
  id          String @id @default(uuid())
  orderItemId String
  optionId    String
  name        String
  priceDelta  Float  @default(0)

  orderItem OrderItem          @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  option    FoodModifierOption @relation(fields: [optionId], references: [id])
}

/**
 * ================= PAYMENT =================
 */

model Payment {
  id String @id @default(uuid())

  orderId      String @unique
  restaurantId String

  provider String
  amount   Float

  status PaymentStatus @default(PENDING)

  transactionId String?
  invoiceUrl    String?
  invoiceNo     String? @unique
  providerRef   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

/**
 * ================= SUBSCRIPTION =================
 */

model Subscription {
  id String @id @default(uuid())

  restaurantId String @unique

  plan      String
  foodLimit Int
  isActive  Boolean @default(true)

  startedAt DateTime  @default(now())
  expiresAt DateTime?

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

/**
 * ================= NOTIFICATION =================
 */

model Notification {
  id String @id @default(uuid())

  restaurantId String
  type         String
  message      String
  isRead       Boolean @default(false)

  createdAt DateTime @default(now())
}

/**
 * ================= LOYALTY =================
 */

model Loyalty {
  id String @id @default(uuid())

  restaurantId String
  phone        String?
  points       Int     @default(0)
  visitCount   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * ================= QR CODE =================
 */

model QRCode {
  id String @id @default(uuid())

  restaurantId String
  tableId      String

  url String

  createdAt DateTime @default(now())
}

model QrScan {
  id             String   @id @default(uuid())
  restaurantId   String
  tableId        String?
  qrId           String?
  guestSessionId String?
  userAgent      String?
  ipAddress      String?
  createdAt      DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table      Table?     @relation(fields: [tableId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([tableId])
  @@index([qrId])
}

/**
 * ================= ANALYTICS =================
 */

model AnalyticsEvent {
  id String @id @default(uuid())

  restaurantId String
  type         String
  payload      Json

  createdAt DateTime @default(now())
}

/**
 * ================= AUDIT LOG =================
 */

model AuditLog {
  id           String  @id @default(uuid())
  restaurantId String?
  userId       String?
  action       String
  entity       String?
  entityId     String?
  oldValue     Json?
  newValue     Json?
  ipAddress    String?
  userAgent    String?

  createdAt DateTime @default(now())

  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([userId])
  @@index([action])
}

/**
 * ================= EVENT RELIABILITY =================
 */

model EventOutbox {
  id        String  @id @default(uuid())
  type      String
  payload   Json
  status    String  @default("PENDING")
  attempts  Int     @default(0)
  lastError String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
}

model ProcessedEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())

  @@index([type])
}
